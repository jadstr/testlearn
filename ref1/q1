#include <iostream>
using namespace std;

int main() {
int n;

cout<<"Enter a number 1 - 21"<<endl;
cin>>n;



for (int i = 1; i <= n; i++) {
    for (int j = 1; j <= n - 1; j++) {
        cout<<" ";
    }
    cout<<endl;
    for (int i = 1; i <= n; i++) {
    for (int j = 1; j <= n - 1; j++) {
        cout<<"*";
    }
    cout<<endl;
   
} 

return 0;










}
